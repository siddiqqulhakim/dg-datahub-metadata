# Staging environment configuration
# DATAHUB_TOKEN is injected from GitHub Actions secret: DATAHUB_TOKEN_STAGING

DATAHUB_ENV=staging
DATAHUB_GMS_URL=http://datahub-gms.staging.internal:8080
DATAHUB_FRONTEND_URL=http://datahub.staging.internal:9002
DATAHUB_PLATFORM_INSTANCE=staging
METADATA_DIR=metadata/
INGESTION_CONFIG_PATTERN=ingestion/sources/*-staging.yaml
DEPLOYMENT_DRY_RUN=false
LOG_LEVEL=INFO

