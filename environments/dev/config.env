# Development environment configuration
# These non-secret values are safe to version-control.
# The DATAHUB_TOKEN is injected by GitHub Actions from repository secrets.

DATAHUB_ENV=dev
DATAHUB_GMS_URL=http://datahub-gms.dev.internal:8080
DATAHUB_FRONTEND_URL=http://datahub.dev.internal:9002
DATAHUB_PLATFORM_INSTANCE=dev
METADATA_DIR=metadata/
INGESTION_CONFIG_PATTERN=ingestion/sources/*-dev.yaml
DEPLOYMENT_DRY_RUN=false
LOG_LEVEL=INFO

