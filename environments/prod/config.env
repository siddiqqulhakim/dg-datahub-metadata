# Production environment configuration
# DATAHUB_TOKEN is injected from GitHub Actions Environment secret: DATAHUB_TOKEN_PROD
# This environment requires 2 mandatory reviewers before deployment proceeds.

DATAHUB_ENV=prod
DATAHUB_GMS_URL=http://datahub-gms.prod.internal:8080
DATAHUB_FRONTEND_URL=http://datahub.prod.internal:9002
DATAHUB_PLATFORM_INSTANCE=prod
METADATA_DIR=metadata/
INGESTION_CONFIG_PATTERN=ingestion/sources/*-prod.yaml
DEPLOYMENT_DRY_RUN=false
LOG_LEVEL=WARNING

